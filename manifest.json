{
  "manifest_version": 3,
  "name": "Promptify",
  "description": "Rewrite rough prompts into clear, specific, high-quality prompts — anywhere in the browser.",
  "version": "1.5.2",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "32": "icons/icon32.png"
  },
  "action": {
    "default_title": "Promptify"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "commands": {
    "refine-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Refine the selected text"
    }
  },
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.anthropic.com/*",
    "https://*.supabase.co/*"
  ]
}
