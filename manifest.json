{
  "manifest_version": 3,
  "name": "Promptify",
  "description": "Rewrite rough prompts into clear, specific, high-quality prompts — anywhere in the browser.",
  "version": "1.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Promptify"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "contextMenus", "scripting", "activeTab"],
  "host_permissions": ["https://openrouter.ai/*", "https://api.anthropic.com/*"]
}
